# Salin ke .env. Untuk skema baru (migrations Goose), disarankan DB terpisah dari Prisma Nuxt.
DATABASE_URL=postgresql://USER@localhost:5432/proferti_go?schema=public

# Port HTTP API
HTTP_ADDR=:8080

# Migrasi: dari folder proferti-be
#   go run ./cmd/migrate up
#   go run ./cmd/migrate down
#   go run ./cmd/migrate status
#   go run ./cmd/migrate version
